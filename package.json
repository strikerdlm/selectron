{
  "name": "selectron",
  "private": true,
  "version": "0.5.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "verify:fast": "npm run typecheck && npx vitest run tests/imm/conditions.test.ts tests/ui/crew-composition.test.tsx tests/ui/imm_session_save_load.test.tsx tests/ui/imm_headline_card.test.tsx tests/ui/health-support.test.tsx",
    "verify:paper": "npm run typecheck && npx vitest run tests/imm/conditions.test.ts && npm run build",
    "verify:e2e": "playwright test",
    "calibrate:imm": "tsx scripts/calibrate_imm_priors.ts",
    "validate:imm": "tsx scripts/validate_imm.ts",
    "validate:imm:analog": "vitest run tests/imm/analog_45d_unscreened_crew.test.ts tests/imm/analog_90d_crew_archetypes.test.ts tests/imm/posterior_predictive.test.ts",
    "evidence:status": "tsx scripts/evidence_status.ts",
    "evidence:require-adjudicated": "tsx scripts/evidence_status.ts --require-adjudicated"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^1.1.7",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^1.6.0"
  }
}
